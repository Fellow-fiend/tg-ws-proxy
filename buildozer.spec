[app]
title = TG WS Proxy
package.name = tgwsproxy
package.domain = org.flowseal
source.dir = .
source.include_exts = py,png,jpg,kv,atlas,json
source.exclude_dirs = .git,__pycache__,packaging
version = 0.1.0
requirements = python3,kivy,cryptography
orientation = portrait
fullscreen = 0

[buildozer]
log_level = 2
warn_on_root = 1
